# ------------------------------------------------------------------
# SnapCart Backend — Environment Variables
# Copy this file to ".env" and fill in your real values.
# Never commit your actual .env file to version control.
# ------------------------------------------------------------------

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development                  # development | production

# ── Database ──────────────────────────────────────────────────────
MONGO_URI=                            # MongoDB Atlas connection string

# ── JWT ───────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=                  # long random string, min 32 chars
REFRESH_TOKEN_SECRET=                 # different long random string, min 32 chars

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                     # from Google Cloud Console
GOOGLE_CLIENT_SECRET=                 # from Google Cloud Console
GOOGLE_CALLBACK_URL=                  # e.g. http://localhost:5000/api/auth/google/callback

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_URL=                         # e.g. http://localhost:5173

# ── Resend (Email) ────────────────────────────────────────────────
RESEND_API_KEY=                       # from resend.com dashboard
RESEND_FROM_EMAIL=                    # e.g. noreply@yourdomain.com

# ── Cloudinary (Image Storage) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=                # cloud name from Cloudinary dashboard
CLOUDINARY_API_KEY=                   # cloudinary API key from Cloudinary dashboard
CLOUDINARY_API_SECRET=                # cloudinary API secret from Cloudinary dashboard